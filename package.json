{
  "name": "@uboness/homebridge-dirigera",
  "version": "0.3.0",
  "author": "uboness",
  "type": "commonjs",
  "publishConfig": {
    "@uboness:registry": "https://registry.npmjs.org "
  },
  "displayName": "Homebridge DIRIGERA",
  "description": "IKEA DIRIGERA Homebridge Plugin",
  "license": "Apache-2.0",
  "keywords": [
    "homebridge-plugin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/uboness/homebridge-dirigera"
  },
  "bugs": {
    "url": "https://github.com/uboness/homebridge-dirigera/issues"
  },
  "engines": {
    "node": "^20.9.0 || ^22.18.0",
    "homebridge": "^1.6.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "files": [
    "tsconfig.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "dist",
    "config.schema.json"
  ],
  "scripts": {
    "clean": "rimraf ./dist",
    "build": "pnpm run clean && tsc",
    "watch": "pnpm run clean && tsc -w",
    "prepublishOnly": "pnpm run build",
    "release:bump": "pnpm run build && commit-and-tag-version",
    "release:bump-minor": "commit-and-tag-version --release-as minor",
    "release:bump-major": "commit-and-tag-version --release-as major",
    "release:postbump": "pnpm run release:push && pnpm run release:publish",
    "release:push": "git push --follow-tags",
    "release:publish": "npm publish --access public",
    "release": "pnpm run release:bump && pnpm run release:postbump",
    "release-minor": "pnpm run release:bump-minor && pnpm run release:push && pnpm run release:publish",
    "release-major": "pnpm run release:bump-major && pnpm run release:push && pnpm run release:publish"
  },
  "dependencies": {
    "dirigera": "^1.4.0",
    "got": "^14.4.7"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "commit-and-tag-version": "^12.5.2",
    "eslint": "^9.33.0",
    "homebridge": "^1.11.0",
    "homebridge-config-ui-x": "^5.4.1",
    "nodemon": "^3.1.10",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
